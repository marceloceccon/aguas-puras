# --- Local / CI ---
# Anvil uses a deterministic default account; no private key needed for `pnpm deploy:local`.

# --- Base Sepolia (testnet) ---
# RPC — coinbase/basescan/alchemy/quicknode/your own.
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org

# EOA that funds the Sepolia deploy. Ownership is transferred to $OWNER right after.
DEPLOYER_PRIVATE_KEY=

# Gnosis Safe addresses (decisions #2 + #3 — resolved 2026-04-18).
# Same Safe holds both roles for the MVP (lab readings + collector allowlist).
LAB_WALLET=
OWNER=

# Basescan API key (decision #6 — resolved 2026-04-18).
# https://basescan.org/myapikey
BASESCAN_API_KEY=

# --- Base Mainnet ---
# Mainnet deploys MUST be executed by the Safe multisig (2-of-3). Use the Safe
# Transaction Builder to craft the deploy tx; DEPLOYER_PRIVATE_KEY is not used here.
BASE_MAINNET_RPC_URL=https://mainnet.base.org
