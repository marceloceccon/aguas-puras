# Which chain to index. One of: anvil | baseSepolia | base
PONDER_NETWORK=anvil

# WaterSampleRegistry address on the selected chain.
REGISTRY_ADDRESS=0x0000000000000000000000000000000000000000

# Block to start indexing from (deployment block of WaterSampleRegistry).
REGISTRY_START_BLOCK=0

# RPC URLs (override per-chain). Defaults are public endpoints / localhost.
PONDER_RPC_URL_31337=http://127.0.0.1:8545
PONDER_RPC_URL_84532=https://sepolia.base.org
PONDER_RPC_URL_8453=https://mainnet.base.org

# Database — Ponder defaults to sqlite in-memory for `ponder dev`. Set for prod.
# DATABASE_URL=postgresql://user:pass@host:5432/db
