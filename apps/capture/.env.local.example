# Base OnchainKit key (https://portal.cdp.coinbase.com) — required for smart-wallet onboarding.
NEXT_PUBLIC_ONCHAINKIT_API_KEY=

# Chain: 84532 (Base Sepolia, default), 8453 (Base mainnet), 31337 (local anvil).
NEXT_PUBLIC_CHAIN_ID=84532

# Optional custom RPC. Leave blank to use wagmi chain default.
NEXT_PUBLIC_RPC_URL=

# Deployed WaterSampleRegistry address on the chain above.
NEXT_PUBLIC_REGISTRY_ADDRESS=0x0000000000000000000000000000000000000000

# EAS schema UID for WaterSampleAttestation. See specification.md §3.
# Needs Decision: not yet registered on any Base network.
NEXT_PUBLIC_EAS_SCHEMA_UID=

# Origin of the public dashboard (used as QR verifier URL prefix on the success screen).
NEXT_PUBLIC_VERIFIER_ORIGIN=http://localhost:3001

# Pinata (decision #4 — resolved 2026-04-18). JWT stays server-side.
# https://app.pinata.cloud/developers/api-keys
PINATA_JWT=

# Public gateway used to surface thumbnails (can be Pinata's or any CIDv1 gateway).
NEXT_PUBLIC_IPFS_GATEWAY=https://gateway.pinata.cloud
