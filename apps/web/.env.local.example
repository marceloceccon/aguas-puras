# Ponder GraphQL endpoint. Use the default when running locally.
NEXT_PUBLIC_PONDER_URL=http://localhost:42069/graphql

# Chain id samples live on (31337 anvil / 84532 Base Sepolia / 8453 Base mainnet).
NEXT_PUBLIC_CHAIN_ID=31337

# WaterSampleRegistry address on that chain (used for deep links + /verify).
NEXT_PUBLIC_REGISTRY_ADDRESS=0x5FbDB2315678afecb367f032d93F642f64180aa3

# CollectorRegistry address on that chain (used for the approved-collectors card).
NEXT_PUBLIC_COLLECTOR_REGISTRY_ADDRESS=0xe7f1725E7734CE288F8367e1Bb143E90bb3F0512

# EAS explorer base URL for the selected chain.
# Leave blank on anvil; examples:
#   Base Sepolia: https://base-sepolia.easscan.org
#   Base mainnet: https://base.easscan.org
NEXT_PUBLIC_EAS_EXPLORER_URL=

# Block explorer base URL for the selected chain.
#   Base Sepolia: https://sepolia.basescan.org
#   Base mainnet: https://basescan.org
NEXT_PUBLIC_BLOCK_EXPLORER_URL=

# Public IPFS gateway (defaults to Pinata's).
NEXT_PUBLIC_IPFS_GATEWAY=https://gateway.pinata.cloud

# -- Admin API (decision #8, resolved 2026-04-18) --
# Master kill-switch. MUST be "true" for POST /api/studies + DELETE to answer.
STUDIES_API_ENABLED=true

# Comma-separated hex addresses permitted to sign admin actions.
# Default: anvil account #0 for local dev. Replace with the operator's wallet.
ADMIN_ALLOWLIST=0xf39Fd6e51aad88F6F4ce6aB8827279cffFb92266
